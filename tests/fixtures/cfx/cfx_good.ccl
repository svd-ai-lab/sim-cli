LIBRARY:
  MATERIAL: Water
    Material Group = User
    Option = Pure Substance
    Thermodynamic State = Liquid
    PROPERTIES:
      Option = General Material
      EQUATION OF STATE:
        Density = 997 [kg m^-3]
        Molar Mass = 18.02 [g mol^-1]
        Option = Value
      END
      DYNAMIC VISCOSITY:
        Dynamic Viscosity = 8.899E-4 [kg m^-1 s^-1]
        Option = Value
      END
    END
  END
END
FLOW: Flow Analysis 1
  SOLUTION UNITS:
    Angle Units = [rad]
    Length Units = [m]
    Mass Units = [kg]
    Temperature Units = [K]
    Time Units = [s]
  END
  ANALYSIS TYPE:
    Option = Steady State
  END
  DOMAIN: Default Domain
    Coord Frame = Coord 0
    Domain Type = Fluid
    Location = FLUID
    BOUNDARY: Inlet
      Boundary Type = INLET
      Location = INLET
      BOUNDARY CONDITIONS:
        MASS AND MOMENTUM:
          Normal Speed = 2 [m s^-1]
          Option = Normal Speed
        END
      END
    END
    BOUNDARY: Outlet
      Boundary Type = OUTLET
      Location = OUTLET
      BOUNDARY CONDITIONS:
        MASS AND MOMENTUM:
          Option = Average Static Pressure
          Relative Pressure = 0 [Pa]
        END
      END
    END
    BOUNDARY: Wall
      Boundary Type = WALL
      BOUNDARY CONDITIONS:
        MASS AND MOMENTUM:
          Option = No Slip Wall
        END
      END
    END
    FLUID MODELS:
      TURBULENCE MODEL:
        Option = SST
      END
    END
  END
  SOLVER CONTROL:
    CONVERGENCE CONTROL:
      Maximum Number of Iterations = 100
    END
    CONVERGENCE CRITERIA:
      Residual Target = 1.E-5
      Residual Type = RMS
    END
  END
END
COMMAND FILE:
  Version = 24.1
END
